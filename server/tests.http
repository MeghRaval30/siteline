### AssetFlow API Tests
# Prerequisite: The API must be running on http://localhost:3000

@baseUrl = http://localhost:3000/api/v1
@adminEmail = admin@assetflow.com
@adminPassword = password123
@authToken = {{login.response.body.data.token}}
@assetId = {{createAsset.response.body.data.asset.id}}
@allocationId = {{allocateAsset.response.body.data.allocation.id}}

### 1. Health Check
GET {{baseUrl}}/health

### 2. Sign Up
# @name signup
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "name": "System Admin",
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### 3. Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### 4. Create Category
POST {{baseUrl}}/categories
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Laptops",
  "description": "Company issued laptops"
}

### 5. Register an Asset
# @name createAsset
POST {{baseUrl}}/assets
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "MacBook Pro M3",
  "category_id": 1,
  "condition": "New",
  "is_bookable": false
}

### 6. Allocate Asset
# @name allocateAsset
POST {{baseUrl}}/assets/{{assetId}}/allocate
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "condition_at_checkout": "Brand new out of box"
}

### 7. Dashboard KPIs
GET {{baseUrl}}/dashboard/kpis
Authorization: Bearer {{authToken}}

### 8. Raise Maintenance Request
POST {{baseUrl}}/maintenance-requests
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "asset_id": {{assetId}},
  "issue_description": "Screen is flickering periodically.",
  "priority": "High"
}

### 9. View Activity Logs
GET {{baseUrl}}/activity-logs
Authorization: Bearer {{authToken}}
