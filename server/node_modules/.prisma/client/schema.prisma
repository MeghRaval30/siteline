generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  department_id Int?
  role          String   @default("Employee")
  status        String   @default("Active")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  department         Department?  @relation("UserDepartment", fields: [department_id], references: [id])
  headed_departments Department[] @relation("DepartmentHead")

  allocations                Allocation[]         @relation("AllocationHolder")
  allocations_made           Allocation[]         @relation("Allocator")
  transfer_requests_to       TransferRequest[]    @relation("TransferRequestTo")
  transfer_requests_by       TransferRequest[]    @relation("TransferRequestBy")
  transfer_requests_approved TransferRequest[]    @relation("TransferRequestApprover")
  maintenance_raised         MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenance_approved       MaintenanceRequest[] @relation("MaintenanceApprover")
  bookings                   Booking[]            @relation("BookingUser")
  audit_cycles_created       AuditCycle[]         @relation("AuditCycleCreator")
  audit_cycles_closed        AuditCycle[]         @relation("AuditCycleCloser")
  audit_items_verified       AuditItem[]          @relation("AuditItemVerifier")
  notifications              Notification[]
  activity_logs              ActivityLog[]
  audit_cycle_auditors       AuditCycleAuditor[]
}

model Department {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  head_user_id   Int?
  parent_dept_id Int?
  status         String   @default("Active")
  created_at     DateTime @default(now())

  head_user   User?        @relation("DepartmentHead", fields: [head_user_id], references: [id])
  parent_dept Department?  @relation("ParentDepartment", fields: [parent_dept_id], references: [id])
  child_depts Department[] @relation("ParentDepartment")
  users       User[]       @relation("UserDepartment")

  allocations          Allocation[]
  transfer_requests_to TransferRequest[]
  bookings             Booking[]
  audit_cycles         AuditCycle[]
}

model AssetCategory {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  description   String?
  custom_fields String?
  created_at    DateTime @default(now())

  assets Asset[]
}

model Asset {
  id                     Int       @id @default(autoincrement())
  asset_tag              String    @unique
  name                   String
  category_id            Int
  serial_number          String?
  acquisition_date       DateTime?
  acquisition_cost       Decimal?
  condition              String
  location               String?
  photo_url              String?
  documents              String?
  is_bookable            Boolean   @default(false)
  status                 String
  pre_maintenance_status String?
  qr_code                String?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  category AssetCategory @relation(fields: [category_id], references: [id])

  allocations          Allocation[]
  transfer_requests    TransferRequest[]
  maintenance_requests MaintenanceRequest[]
  bookings             Booking[]
  audit_items          AuditItem[]
}

model Allocation {
  id                    Int       @id @default(autoincrement())
  asset_id              Int
  holder_user_id        Int?
  holder_department_id  Int?
  allocated_by          Int
  allocated_at          DateTime  @default(now())
  expected_return_date  DateTime?
  actual_return_date    DateTime?
  condition_at_checkout String
  condition_at_checkin  String?
  status                String
  created_at            DateTime  @default(now())

  asset             Asset       @relation(fields: [asset_id], references: [id])
  holder_user       User?       @relation("AllocationHolder", fields: [holder_user_id], references: [id])
  holder_department Department? @relation(fields: [holder_department_id], references: [id])
  allocator         User        @relation("Allocator", fields: [allocated_by], references: [id])

  transfer_requests_from TransferRequest[]
}

model TransferRequest {
  id                         Int       @id @default(autoincrement())
  asset_id                   Int
  from_allocation_id         Int
  requested_to_user_id       Int?
  requested_to_department_id Int?
  requested_by               Int
  status                     String
  approved_by                Int?
  requested_at               DateTime  @default(now())
  resolved_at                DateTime?
  notes                      String?

  asset                   Asset       @relation(fields: [asset_id], references: [id])
  from_allocation         Allocation  @relation(fields: [from_allocation_id], references: [id])
  requested_to_user       User?       @relation("TransferRequestTo", fields: [requested_to_user_id], references: [id])
  requested_to_department Department? @relation(fields: [requested_to_department_id], references: [id])
  requester               User        @relation("TransferRequestBy", fields: [requested_by], references: [id])
  approver                User?       @relation("TransferRequestApprover", fields: [approved_by], references: [id])
}

model MaintenanceRequest {
  id                Int       @id @default(autoincrement())
  asset_id          Int
  raised_by         Int
  issue_description String
  priority          String
  photo_url         String?
  status            String
  approved_by       Int?
  rejected_reason   String?
  technician_name   String?
  resolution_notes  String?
  created_at        DateTime  @default(now())
  resolved_at       DateTime?

  asset    Asset @relation(fields: [asset_id], references: [id])
  raiser   User  @relation("MaintenanceRaisedBy", fields: [raised_by], references: [id])
  approver User? @relation("MaintenanceApprover", fields: [approved_by], references: [id])
}

model Booking {
  id                         Int       @id @default(autoincrement())
  asset_id                   Int
  booked_by                  Int
  on_behalf_of_department_id Int?
  start_time                 DateTime
  end_time                   DateTime
  status                     String
  purpose                    String?
  cancelled_by               Int?
  cancelled_at               DateTime?
  created_at                 DateTime  @default(now())

  asset             Asset       @relation(fields: [asset_id], references: [id])
  user              User        @relation("BookingUser", fields: [booked_by], references: [id])
  on_behalf_of_dept Department? @relation(fields: [on_behalf_of_department_id], references: [id])
}

model AuditCycle {
  id                  Int       @id @default(autoincrement())
  name                String
  scope_department_id Int?
  scope_location      String?
  start_date          DateTime
  end_date            DateTime
  status              String
  created_by          Int
  closed_by           Int?
  closed_at           DateTime?

  scope_department Department? @relation(fields: [scope_department_id], references: [id])
  creator          User        @relation("AuditCycleCreator", fields: [created_by], references: [id])
  closer           User?       @relation("AuditCycleCloser", fields: [closed_by], references: [id])

  audit_items AuditItem[]
  auditors    AuditCycleAuditor[]
}

model AuditCycleAuditor {
  audit_cycle_id  Int
  auditor_user_id Int

  audit_cycle AuditCycle @relation(fields: [audit_cycle_id], references: [id])
  auditor     User       @relation(fields: [auditor_user_id], references: [id])

  @@id([audit_cycle_id, auditor_user_id])
}

model AuditItem {
  id             Int       @id @default(autoincrement())
  audit_cycle_id Int
  asset_id       Int
  result         String
  notes          String?
  verified_by    Int?
  verified_at    DateTime?

  audit_cycle AuditCycle @relation(fields: [audit_cycle_id], references: [id])
  asset       Asset      @relation(fields: [asset_id], references: [id])
  verifier    User?      @relation("AuditItemVerifier", fields: [verified_by], references: [id])
}

model Notification {
  id                  Int      @id @default(autoincrement())
  user_id             Int
  type                String
  message             String
  related_entity_type String?
  related_entity_id   Int?
  is_read             Boolean  @default(false)
  created_at          DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}

model ActivityLog {
  id            Int      @id @default(autoincrement())
  actor_user_id Int?
  action        String
  entity_type   String?
  entity_id     Int?
  metadata      String?
  created_at    DateTime @default(now())

  actor User? @relation(fields: [actor_user_id], references: [id])
}
